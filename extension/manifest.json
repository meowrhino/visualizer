{
  "manifest_version": 3,
  "name": "Visualizer Screenshot",
  "description": "Captura la pestaña actual para meowrhino visualizer",
  "version": "1.0.0",
  "permissions": ["activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": [
      "https://meowrhino.github.io/visualizer/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "externally_connectable": {
    "matches": [
      "https://meowrhino.github.io/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
